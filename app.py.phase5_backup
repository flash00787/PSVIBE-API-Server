# ═══════════════════════════════════════
#  fetch_promotions_cached
# ═══════════════════════════════════════
@app.get("/api/fetch_promotions_cached", tags=["Promotions"])
async def api_fetch_promotions_cached(auth=Depends(verify_api_key)):
    """Fetch active promotions — MySQL path with gspread fallback."""
    data = _fetch_promotions_cached_from_mysql()
    if data is not None:
        return ok(data)
    try:
        today = today_str()
        ws = get_worksheet(SHEET_PROMOTIONS)
        rows = ws.get_all_values()
        promos = []
        if len(rows) < 2:
            return ok([])

        # Build header-index map for flexible column order
        headers_raw = rows[0]
        header_map = {h.strip().lower().replace(" ", "_"): i for i, h in enumerate(headers_raw)}

        def col(key, row, default=""):
            idx = header_map.get(key, -1)
            if idx >= 0 and idx < len(row):
                val = row[idx].strip()
                return val if val else default
            return default

        for row in rows[1:]:
            if not row or not any(c.strip() for c in row):
                continue

            # Check active flag
            is_active = col("active", row, "") or col("is_active", row, "") or col("status", row, "")
            if is_active.upper() in ("FALSE", "NO", "INACTIVE", "0", "OFF"):
                continue

            valid_until = col("valid_until", row, "") or col("expires", row, "") or col("end_date", row, "")

            # Only return active promotions (valid_until >= today or empty = always active)
            if valid_until:
                try:
                    parts = valid_until.replace("-", "/").split("/")
                    from datetime import date
                    if len(parts) >= 3:
                        if len(parts[2]) == 4:
                            y, m, d = int(parts[2]), int(parts[0]), int(parts[1])
                        elif len(parts[0]) == 4:
                            y, m, d = int(parts[0]), int(parts[1]), int(parts[2])
                        else:
                            raise ValueError(f"Unparseable date: {valid_until}")
                        v_date = date(y, m, d)
                        t_parts = today.replace("-", "/").split("/")
                        t_date = date(int(t_parts[2]), int(t_parts[0]), int(t_parts[1]))
                        if v_date < t_date:
                            continue
                except (ValueError, IndexError):
                    pass

            promos.append({
                "title": col("title", row, "Promotion"),
                "description": col("description", row, ""),
                "type": col("type", row, "general") or col("promo_type", row, "general"),
                "discount_percent": col("discount_percent", row, "") or col("discount", row, ""),
                "item_name": col("item_name", row, ""),
                "bundle_items": col("bundle_items", row, ""),
                "cashback_percent": col("cashback_percent", row, "") or col("cashback", row, ""),
                "conditions": col("conditions", row, ""),
                "valid_until": valid_until,
                "emoji": col("emoji", row, "🎁") or col("icon", row, "🎁"),
            })

        return ok(promos)
    except Exception as e:
        logger.warning("fetch_promotions_cached error: %s", e)
        return ok([], f"Error loading promotions: {str(e)}")


