        payment_method = data.get("payment_method", "Cash")
        staff_name = data.get("staff_name", "")
        date = data.get("date", now_mmt().strftime("%Y-%m-%d"))
        if not member_id:
            raise HTTPException(status_code=400, detail="member_id required")
        if amount <= 0:
            raise HTTPException(status_code=400, detail="amount must be positive")
        if _use_mysql():
            mysql_execute(
                "INSERT INTO topup_log (member_id, amount, topup_date, staff_name, payment_method) "
                "VALUES (%s, %s, %s, %s, %s)",
                (member_id, amount, date, staff_name, payment_method)
            )
            # Update wallet balance
            mysql_execute(
                "UPDATE member_wallets SET balance_mins = balance_mins + %s, total_spend = COALESCE(total_spend,0) + %s WHERE member_id = %s",
                (amount, amount, member_id)
            )
        # Update GSheet
        try:
            from sheets_client import get_worksheet, invalidate_cache
            ws = get_worksheet("Card_Wallet")
            rows = ws.get_all_values()
            for i, row in enumerate(rows[1:], start=2):
