@app.post("/api/sales/record", tags=["Sales"])
async def api_sales_record(req: dict, auth=Depends(verify_api_key)):
    """Record a daily sale into sales_daily table + update member wallet + trigger GSheet sync."""
    try:
        import json as _json
        receipt_no = req.get("receipt_no", "")
        voucher_no = req.get("voucher_no", receipt_no)
        items = req.get("items", "")
        amount = req.get("amount", 0)
        gross = req.get("gross", amount)
        discount = req.get("discount", 0)
        net = req.get("net", amount)
        payment_method = req.get("payment_method", "")
        member_id = req.get("member_id", "")
        staff_name = req.get("staff_name", "")
        receipt_date = req.get("receipt_date", "") or now_mmt().strftime("%Y-%m-%d")
        food_items = req.get("food_items", "")
        food_cost = req.get("food_cost", 0)
        mins_used = req.get("mins_used", 0)

        notes = _json.dumps({
            "receipt_no": receipt_no,
            "items": items,
            "food_items": food_items,
            "food_cost": food_cost
        })

        logger.info("Recording sale: voucher=%s member=%s amount=%s mins_used=%s",
                    voucher_no, member_id, net, mins_used)

        mysql_execute(
            "INSERT INTO sales_daily "
            "(voucher_no, sale_date, member_id, amount, gross, discount, net, staff_name, payment_method, notes) "
            "VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)",
            (voucher_no, receipt_date, member_id, amount, gross, discount, net, staff_name, payment_method, notes)
        )

        # Update member wallet: deduct minutes, increment total_spend
        if member_id and (mins_used > 0 or float(net or 0) > 0):
            try:
                mysql_execute(
                    "UPDATE member_wallets SET "
                    "balance_mins = GREATEST(balance_mins - %s, 0), "
                    "total_used_mins = total_used_mins + %s, "
                    "total_spend = total_spend + %s "
                    "WHERE member_id = %s",
                    (mins_used, mins_used, float(net or 0), member_id)
                )
                logger.info("Wallet updated: member=%s deducted=%s mins, spent=%s", member_id, mins_used, net)
            except Exception as wallet_err:
                logger.warning("Wallet update failed (non-fatal): %s", wallet_err)

        # Trigger background GSheet sync for this member
        _trigger_gsheet_sync("member_wallets", member_id)

        logger.info("Sale recorded: voucher_no=%s", voucher_no)
        return {"status": "ok", "voucher_no": voucher_no}
    except Exception as e:
        logger.error("Sale record error: %s", str(e))
