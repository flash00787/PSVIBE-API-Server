def _fetch_member_data_from_mysql(member_id):
    """Try MySQL member_wallets first, fall back to members table.
    
    member_wallets is populated by the GSheet→MySQL sync, but new members
    created via the API may not yet be mirrored to Google Sheets, and the
    sync's orphan cleanup can delete them from member_wallets before the
    GSheet write completes.  The members table (populated at create time)
    serves as a reliable fallback for API-created members.
    """
    try:
        if _use_mysql():
            row = mysql_query_one("SELECT * FROM member_wallets WHERE member_id = %s", (member_id,))
            if row:
                return row
            # Fallback: read from members table (populated at API create time)
            row = mysql_query_one(
                "SELECT member_id, name AS member_name, phone, balance_minutes AS balance_mins, "
                "'Warrior' AS tier, 0 AS total_spend, 0 AS lifetime_spend, "
                "0 AS ranking_net_spend FROM members WHERE member_id = %s",
                (member_id,))
            if row:
                return row
    except Exception:
        pass
    return None


