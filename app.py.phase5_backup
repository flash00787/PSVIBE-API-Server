@app.post("/api/dashboard/wallet/adjust", tags=["Dashboard"])
async def api_adjust_wallet(data: dict, auth=Depends(verify_api_key)):
    """+/- mins with reason. Write to MySQL + GSheet + log."""
    try:
        member_id = data.get("member_id", "")
        amount = int(data.get("amount", 0))
        reason = data.get("reason", "")
        if not member_id:
            raise HTTPException(status_code=400, detail="member_id required")
        if amount == 0:
            raise HTTPException(status_code=400, detail="amount must be non-zero")
        if not reason:
            raise HTTPException(status_code=400, detail="reason required")
        if _use_mysql():
            mysql_execute(
                "UPDATE member_wallets SET balance_mins = balance_mins + %s WHERE member_id = %s",
                (amount, member_id)
            )
            now_dt = now_mmt().strftime("%Y-%m-%d %H:%M:%S")
            try:
                mysql_execute(
                    "INSERT INTO wallet_adjustments (member_id, amount, reason, created_at) VALUES (%s, %s, %s, %s)",
                    (member_id, amount, reason, now_dt)
                )
            except Exception:
                pass  # table may not exist yet
        # Update GSheet
        try:
            from sheets_client import get_worksheet, invalidate_cache
            ws = get_worksheet("Card_Wallet")
            rows = ws.get_all_values()
            for i, row in enumerate(rows[1:], start=2):
                if len(row) > 1 and row[1].strip() == member_id.strip():
                    current = int_safe(row[7]) if len(row) > 7 and row[7].strip() else 0
                    new_balance = current + amount
                    ws.update_cell(i, 8, new_balance)
                    if amount > 0:
                        current_bought = int_safe(row[8]) if len(row) > 8 else 0
                        ws.update_cell(i, 9, current_bought + amount)
                    else:
                        current_used = int_safe(row[9]) if len(row) > 9 else 0
                        ws.update_cell(i, 10, current_used + abs(amount))
                    break
            invalidate_cache("member")
        except Exception as gs_err:
            logger.warning("GSheet wallet adjust failed for %s: %s", member_id, gs_err)
        logger.info("Wallet adjusted: member=%s amount=%+d reason=%s", member_id, amount, reason)
        return ok({"adjusted": True, "member_id": member_id, "amount": amount})
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/dashboard/topup", tags=["Dashboard"])
async def api_dashboard_topup(data: dict, auth=Depends(verify_api_key)):
