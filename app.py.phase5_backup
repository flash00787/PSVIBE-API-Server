@app.get("/api/next_voucher", tags=["Sales"])
async def api_next_voucher(auth=Depends(verify_api_key)):
    """Generate next voucher number (MySQL sales_daily/receipts first, Sheets fallback)."""
    try:
        if _use_mysql():
            # Try sales_daily first (voucher_no column)
            row = mysql_query_one(
                "SELECT voucher_no FROM sales_daily WHERE voucher_no IS NOT NULL AND voucher_no LIKE 'V-%%' ORDER BY id DESC LIMIT 1"
            )
            if row and row.get("voucher_no"):
                vid = row["voucher_no"]
                try:
                    return ok(f"V-{int(vid.split('-')[1]) + 1:03d}")
                except (IndexError, ValueError):
                    pass
            # Try receipts table as fallback
            row = mysql_query_one(
                "SELECT receipt_no FROM receipts WHERE receipt_no IS NOT NULL AND receipt_no LIKE 'V-%%' ORDER BY id DESC LIMIT 1"
            )
            if row and row.get("receipt_no"):
                rid = row["receipt_no"]
                try:
                    return ok(f"V-{int(rid.split('-')[1]) + 1:03d}")
                except (IndexError, ValueError):
                    pass
        # Fallback: Google Sheets Sales_Daily col B
        ws = get_worksheet(SHEET_SALES_DAILY)
        col = ws.col_values(2)
        ids = [v for v in col[1:] if v.upper().startswith("V-")]
        if ids:
            try:
                return ok(f"V-{int(ids[-1].split('-')[1]) + 1:03d}")
            except (IndexError, ValueError):
                pass
        return ok("V-001")
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


