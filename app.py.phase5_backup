            (member_id,)
        )
        if not current:
            return {"status": "error", "detail": f"Member not found: {member_id}"}

        balance_before = current["balance_mins"]

        mysql_execute(
            "UPDATE member_wallets SET "
            "balance_mins = GREATEST(balance_mins - %s, 0), "
            "total_used_mins = total_used_mins + %s "
            "WHERE member_id = %s",
            (mins, mins, member_id)
        )

        new_balance = max(balance_before - mins, 0)
        logger.info("Wallet deducted: member=%s balance %s -> %s (-%s mins)",
                    member_id, balance_before, new_balance, mins)

        _trigger_gsheet_sync("member_wallets", member_id)

        return {
            "status": "ok",
            "member_id": member_id,
            "balance_before": balance_before,
            "balance_after": new_balance,
            "mins_deducted": mins,
