            )
            if row:
                total = float(row["total_spend"]) if row["total_spend"] else 0.0
                balance = float(row["balance_mins"]) if row["balance_mins"] else 0.0
                tier = row["tier"] or "Warrior"
                master = float(_get_setting("master_threshold", 300000))
                immortal = float(_get_setting("immortal_threshold", 1000000))
                if total >= immortal:
                    tier = "Immortal"
                elif total >= master:
                    tier = "Master"
                else:
                    tier = "Warrior"
                return ok({"tier": tier, "total_spend": total, "balance_mins": balance})
        # gspread fallback
        for row in get_member_rows()[1:]:
            if len(row) > 1 and row[1].strip() == member_id.strip():
                tier = row[6].strip() if len(row) > 6 else ""
                return ok(tier if tier else "Warrior")
        raise HTTPException(status_code=404, detail=f"Member {member_id} not found")
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


