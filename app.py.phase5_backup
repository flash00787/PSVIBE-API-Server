    try:
        product_name = req.get("product_name", "")
        quantity = int(req.get("quantity", 0))
        if not product_name or quantity <= 0:
            raise HTTPException(status_code=400, detail="product_name and quantity>0 required")
        result = inventory_fifo.deduct(product_name, quantity)
        if "error" in result:
            raise HTTPException(status_code=400, detail=result["error"])
        logger.info("Stock deducted: %s qty=%s remaining=%s fifo_cost=%s",
                    product_name, quantity, result["remaining"], result["fifo_cost"])
        return ok(result)
    except HTTPException:
