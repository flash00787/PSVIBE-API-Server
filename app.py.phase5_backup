def _trigger_gsheet_sync(sheet_name: str, member_id: str = None):
    """Trigger a background GSheet sync for a specific sheet/member.

    This runs asynchronously in a thread to avoid blocking the API response.
    Currently logs the trigger; full background sync via sync_service can be
    enabled later.
    """
    try:
        import threading

        def _sync_worker():
            try:
                logger.debug("Background sync triggered: sheet=%s member=%s", sheet_name, member_id)
                # Future: call sync_service methods here
                # from sync_service import get_sync_service
                # svc = get_sync_service()
                # if sheet_name == "member_wallets":
                #     svc.sync_member_wallets()
            except Exception as e:
                logger.warning("Background sync worker error: %s", e)

        t = threading.Thread(target=_sync_worker, name=f"gsheet-sync-{sheet_name}", daemon=True)
        t.start()
    except Exception as e:
        logger.warning("Could not trigger background sync: %s", e)



