@app.get("/api/sheets/weekly-report", tags=["Sheets"])
async def api_sheets_weekly_report(auth=Depends(verify_api_key)):
    """Return weekly aggregated report data. MySQL-first with gspread fallback."""
    try:
        mmt = now_mmt()
        weekday = mmt.weekday()
        week_start = mmt - timedelta(days=weekday)
        week_start = week_start.replace(hour=0, minute=0, second=0, microsecond=0)
        
        result = {
            "week_start": week_start.strftime("%Y-%m-%d"),
            "week_end": (week_start + timedelta(days=7)).strftime("%Y-%m-%d"),
            "daily_revenue": {},
            "total_revenue": 0,
            "total_vouchers": 0,
            "total_topups": 0,
            "topup_revenue": 0,
        }

        # ── MySQL-first: Sales ──
        mysql_sales = False
        try:
            from datetime import datetime as _dt
            week_start_str = week_start.strftime("%-m/%-d/%Y")
            week_end_dt = week_start + timedelta(days=7)
            rows, err = _mysql_try_query("SELECT * FROM sales_daily")
            if rows is not None and len(rows) > 0:
                mysql_sales = True
                for row in rows:
                    d = (row.get("date", "") or "").strip()
                    dt = _parse_mm_dd_yyyy(d)
                    if dt is None:
                        continue
                    dt_mmt = dt.replace(tzinfo=MMT_TZ)
                    if dt_mmt < week_start or dt_mmt >= week_end_dt:
                        continue
                    day_key = dt.strftime("%Y-%m-%d")
                    amt = int(row.get("amount", 0)) if row.get("amount") is not None else 0
                    if day_key not in result["daily_revenue"]:
                        result["daily_revenue"][day_key] = 0
                    result["daily_revenue"][day_key] += amt
                    result["total_revenue"] += amt
                    result["total_vouchers"] += 1
        except Exception as e:
            logger.warning("weekly-report mysql sales error: %s", e)

        if not mysql_sales:
            try:
                from sheets_client import get_sales_daily_rows, get_topup_log_rows
                sd_raw = get_sales_daily_rows()
                for row in sd_raw[1:]:
                    if len(row) < 5:
                        continue
                    d = row[2].strip() if len(row) > 2 else ""
                    dt = _parse_mm_dd_yyyy(d)
                    if dt is None:
                        continue
                    dt_mmt = dt.replace(tzinfo=MMT_TZ)
                    if dt_mmt < week_start:
                        continue
                    day_key = dt.strftime("%Y-%m-%d")
                    amt = int_safe(row[4]) if len(row) > 4 else 0
                    if day_key not in result["daily_revenue"]:
                        result["daily_revenue"][day_key] = 0
                    result["daily_revenue"][day_key] += amt
                    result["total_revenue"] += amt
                    result["total_vouchers"] += 1
            except Exception as e:
                logger.warning("weekly-report sales gspread error: %s", e)

        # ── MySQL-first: Topups ──
        mysql_tu = False
        try:
            week_end_dt = week_start + timedelta(days=7)
            rows, err = _mysql_try_query("SELECT * FROM topup_log")
            if rows is not None and len(rows) > 0:
                mysql_tu = True
                for row in rows:
                    d = (row.get("date", "") or "").strip()
                    dt = _parse_mm_dd_yyyy(d)
                    if dt is None:
                        continue
                    dt_mmt = dt.replace(tzinfo=MMT_TZ)
                    if dt_mmt < week_start or dt_mmt >= week_end_dt:
                        continue
                    amt = int(row.get("amount", 0)) if row.get("amount") is not None else 0
                    result["total_topups"] += 1
                    result["topup_revenue"] += amt
                    result["total_revenue"] += amt
        except Exception as e:
            logger.warning("weekly-report mysql topup error: %s", e)

        if not mysql_tu:
            try:
                from sheets_client import get_topup_log_rows
                tu_rows = get_topup_log_rows()
                for row in tu_rows[1:]:
                    if len(row) < 4:
                        continue
                    d = row[0].strip() if len(row) > 0 else ""
                    dt = _parse_mm_dd_yyyy(d)
                    if dt is None:
                        continue
                    dt_mmt = dt.replace(tzinfo=MMT_TZ)
                    if dt_mmt < week_start:
                        continue
                    amt = int_safe(row[3]) if len(row) > 3 else 0
                    result["total_topups"] += 1
                    result["topup_revenue"] += amt
                    result["total_revenue"] += amt
            except Exception as e:
                logger.warning("weekly-report topup gspread error: %s", e)

        return ok(result)
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

