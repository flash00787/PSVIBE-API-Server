@app.get("/api/finance/pnl", tags=["Finance"])
async def api_finance_pnl(m: str = Query("", description="Month in YYYY-MM format"), auth=Depends(verify_api_key)):
    """Return P&L data for a month. MySQL-first with gspread fallback."""
    mmt = now_mmt()
    month = m if m else f"{mmt.year}-{mmt.month:02d}"
    month_slash = month.replace("-", "/")
    
    result = {
        "month": month,
        "revenue": {"console": 0, "food": 0, "products": 0, "topup": 0, "other": 0},
        "cogs": 0,
        "gross_profit": 0,
        "expenses": {"salaries": 0, "rent": 0, "utilities": 0, "supplies": 0, "other": 0},
        "total_revenue": 0,
        "total_expenses": 0,
        "net_profit": 0,
    }

    # ── MySQL-first: Console revenue ──
    mysql_sales = False
    try:
        rows, err = _mysql_try_query("SELECT * FROM sales_daily WHERE date LIKE %s", (f"%{month_slash}%",))
        if rows is not None and len(rows) > 0:
            mysql_sales = True
            for row in rows:
                amt = int(row.get("amount", 0)) if row.get("amount") is not None else 0
                result["revenue"]["console"] += amt
                result["total_revenue"] += amt
    except Exception as e:
        logger.warning("finance/pnl mysql sales error: %s", e)

    if not mysql_sales:
        try:
            from sheets_client import get_sales_daily_rows, get_topup_log_rows
            sd_raw = get_sales_daily_rows()
            for row in sd_raw[1:]:
                if len(row) < 5:
                    continue
                d = row[2].strip() if len(row) > 2 else ""
                if month_slash not in d:
                    continue
                amt = int_safe(row[4]) if len(row) > 4 else 0
                result["revenue"]["console"] += amt
                result["total_revenue"] += amt
        except Exception as e:
            logger.warning("finance/pnl sales gspread error: %s", e)

    # ── MySQL-first: TopUp revenue ──
    mysql_topup = False
    try:
        rows, err = _mysql_try_query("SELECT * FROM topup_log WHERE date LIKE %s", (f"%{month_slash}%",))
        if rows is not None and len(rows) > 0:
            mysql_topup = True
            for row in rows:
                amt = int(row.get("amount", 0)) if row.get("amount") is not None else 0
                result["revenue"]["topup"] += amt
                result["total_revenue"] += amt
    except Exception as e:
        logger.warning("finance/pnl mysql topup error: %s", e)

    if not mysql_topup:
        try:
            from sheets_client import get_topup_log_rows
            tu_rows = get_topup_log_rows()
            for row in tu_rows[1:]:
                if len(row) < 4:
                    continue
                d = row[0].strip() if len(row) > 0 else ""
                if month_slash not in d:
                    continue
                amt = int_safe(row[3]) if len(row) > 3 else 0
                result["revenue"]["topup"] += amt
                result["total_revenue"] += amt
        except Exception as e:
            logger.warning("finance/pnl topup gspread error: %s", e)

    # ── MySQL-first: Expenses (salaries) ──
    mysql_sal = False
    try:
        rows, err = _mysql_try_query("SELECT * FROM staff_records WHERE is_active = 1")
        if rows is not None and len(rows) > 0:
            mysql_sal = True
            for row in rows:
                sal = int(row.get("base_salary", 0)) if row.get("base_salary") is not None else 0
                result["expenses"]["salaries"] += sal
    except Exception as e:
        logger.warning("finance/pnl mysql salary error: %s", e)

    if not mysql_sal:
        try:
            ws = get_worksheet(SHEET_SETTING)
            salaries = ws.col_values(20)[1:]
            for s in salaries:
                result["expenses"]["salaries"] += int_safe(s)
        except Exception:
            pass

    result["total_expenses"] = sum(result["expenses"].values())
    result["gross_profit"] = result["total_revenue"] - result["cogs"]
    result["net_profit"] = result["total_revenue"] - result["total_expenses"]

    return ok(result)

@app.get("/api/finance/balance-sheet", tags=["Finance"])
async def api_finance_balance_sheet(auth=Depends(verify_api_key)):
    """Return balance sheet summary. MySQL-first with gspread fallback."""
    result = {
        "assets": {"cash": 0, "inventory_value": 0, "equipment_value": 0, "total": 0},
        "liabilities": {"wallet_liability": 0, "advances": 0, "payables": 0, "total": 0},
        "equity": {"retained_earnings": 0, "total": 0},
    }

    # ── MySQL-first: Wallet liability ──
    mysql_wallet = False
    try:
        rows, err = _mysql_try_query("SELECT * FROM card_wallet")
        if rows is not None and len(rows) > 0:
            mysql_wallet = True
            for row in rows:
                mins = int(row.get("balance_mins", 0)) if row.get("balance_mins") is not None else 0
                result["liabilities"]["wallet_liability"] += mins
    except Exception as e:
        logger.warning("balance-sheet mysql wallet error: %s", e)

    if not mysql_wallet:
        for row in get_member_rows()[1:]:
            if len(row) > 7:
                mins = int_safe(row[7]) if row[7].strip() else 0
                result["liabilities"]["wallet_liability"] += mins

    # ── MySQL-first: Base rate conversion ──
    mysql_rate = False
    try:
        rows, err = _mysql_try_query("SELECT * FROM setting WHERE setting_key = %s", ("base_rate",))
        if rows is not None and len(rows) > 0:
            mysql_rate = True
            base_rate = int(rows[0].get("setting_value", 0)) if rows[0].get("setting_value") is not None else 0
            if base_rate > 0:
                result["liabilities"]["wallet_liability"] = int(result["liabilities"]["wallet_liability"] * base_rate / 60)
    except Exception as e:
        logger.warning("balance-sheet mysql rate error: %s", e)

    if not mysql_rate:
        try:
            ws = get_worksheet(SHEET_SETTING)
            base_rate = int_safe(ws.cell(2, 2).value)
            if base_rate > 0:
                result["liabilities"]["wallet_liability"] = int(result["liabilities"]["wallet_liability"] * base_rate / 60)
        except Exception:
            result["liabilities"]["wallet_liability"] = 0

    # ── MySQL-first: Advances ──
    mysql_adv = False
    try:
        mmt = now_mmt()
        month_slash = f"{mmt.month}/{mmt.year}"
        rows, err = _mysql_try_query("SELECT * FROM salary_advance WHERE date LIKE %s", (f"%{month_slash}%",))
        if rows is not None and len(rows) > 0:
            mysql_adv = True
            for row in rows:
                amt = int(row.get("amount", 0)) if row.get("amount") is not None else 0
                result["liabilities"]["advances"] += amt
    except Exception as e:
        logger.warning("balance-sheet mysql advance error: %s", e)

    result["liabilities"]["total"] = result["liabilities"]["wallet_liability"] + result["liabilities"]["advances"]
    result["assets"]["total"] = result["liabilities"]["total"] + result["equity"]["total"]
    
    return ok(result)

