# ═══════════════════════════════════════
#  HELPER — date parsing
# ═══════════════════════════════════════
def _parse_mm_dd_yyyy(val: str):
    """Parse M/D/YYYY or MM/DD/YYYY string to datetime."""
    if not val or not val.strip():
        return None
    val = val.strip()
    for fmt in ("%m/%d/%Y", "%-m/%-d/%Y", "%Y-%m-%d"):
        try:
            return datetime.strptime(val, fmt)
        except ValueError:
            continue
    return None

