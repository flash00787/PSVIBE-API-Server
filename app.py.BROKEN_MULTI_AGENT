    month_str = req.get("month_str", "")
    staff = req.get("staff", "")
    leave_days = req.get("leave_days", 0)
    late_count = req.get("late_count", 0)
    deduct_per_late = req.get("deduct_per_late", 500)

    try:
        mysql_save_attendance(month_str, staff, leave_days, late_count, deduct_per_late)
        logger.info("save_attendance: saved to MySQL (%s/%s)", month_str, staff)
        return ok({"staff": staff, "month": month_str})
    except Exception as e:
        logger.warning("MySQL save_attendance failed, falling back to gspread: %s", e)

    try:
        sh = get_worksheet(SHEET_ATTENDANCE_LOG)
        rows = sh.get_all_values()
        found = False
        for i, row in enumerate(rows[1:], start=2):
