# ── Salary advance helpers ──

def mysql_get_salary_advances(month_str: str):
    """Get salary advances for a month."""
    month_slash = month_str.replace("-", "/")
    rows = query(
        "SELECT staff_name, amount, pay_method FROM salary_advances "
        "WHERE (date_str LIKE %s OR date_str LIKE %s)",
        (f"%{month_str}%", f"%{month_slash}%")
    )
    result = {}
    for r in rows:
        staff = r['staff_name']
        if staff not in result:
            result[staff] = {"total": 0, "cash": 0, "kpay": 0}
        result[staff]["total"] += r['amount']
        if r.get('pay_method', '').upper() == "KPAY":
            result[staff]["kpay"] += r['amount']
        else:
            result[staff]["cash"] += r['amount']
    return result

